class Solution(object):
    def calculate(self, s):
        """
        :type s: str
        :rtype: int
        """
        stack = []
        num = 0
        sign = 1
        ans = 0
        for ch in s:
            if ch.isdigit():
                num = num * 10 + int(ch)
            elif ch in "+-":
                ans += sign * num
                num = 0
                sign = 1 if ch == "+" else -1
            elif ch == "(":
                stack.append(ans)
                stack.append(sign)
                ans = 0
                sign = 1
            elif ch == ")":
                ans += sign * num
                num = 0
                ans *= stack.pop()
                ans += stack.pop()
        return ans + sign * num 
