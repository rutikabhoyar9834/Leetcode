class Solution(object):
    def divide(self, dividend, divisor):
        """
        :type dividend: int
        :type divisor: int
        :rtype: int
        """
        sign = -1 if dividend * divisor < 0 else 1
        dividend = abs(dividend)
        divisor = abs(divisor)
        count = 0
        while dividend >= divisor:
            dividend -= divisor
            count += 1
        return max(min(sign * count, 2**31-1), -2**31)
