class Solution(object):
    def getPermutation(self, n, k):
        """
        :type n: int
        :type k: int
        :rtype: str
        """
        nums = [str(i) for i in range(1, n + 1)]
        k -= 1
        ans = ""
        while nums:
            f = factorial(len(nums) - 1)
            index = k // f
            ans += nums[index]
            nums.pop(index)
            k = k % f
        return ans   
