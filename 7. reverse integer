class Solution(object):
    def reverse(self, x):
        """
        :type x: int
        :rtype: int
        """
        sign = -1 if x < 0 else 1
        x = abs(x)
        rev = int(str(x)[::-1])
        rev = rev * sign
        if rev < -2147483648 or rev > 2147483647:
            return 0
        return rev    
